# Postgres the server connects to. The server creates/uses a dedicated `stout`
# database on this instance, so point DATABASE_URL at the maintenance database
# (commonly `postgres`). The server will switch to the `stout` database itself.
DATABASE_URL=postgres://stout:stout@localhost:5432/postgres

# Name of the dedicated application database the server creates/uses.
STOUT_DB_NAME=stout

# Directory holding the note repository: a bare repo (`repo.git`, the canonical
# store) and a working clone (`clone`) the server reads/edits. In the container
# this is the mounted `/data` volume; locally it defaults to `./data`.
STOUT_DATA_DIR=data

# Port the server listens on.
PORT=3000

# --- Electron desktop (local-first) — all optional ---
# The desktop app runs the same API + UI over a LOCAL Git working clone under the
# app's user-data directory; it needs no server and, by default, no network. To
# sync that clone with a remote "hub", set STOUT_HUB_URL to the hub's Git remote
# (HTTPS). On first run the desktop clones it; thereafter it pulls-then-pushes.
# Leave unset for a fully-local desktop (no sync).
# STOUT_HUB_URL=https://github.com/you/your-notes.git

# Branch on the hub to clone/sync. Defaults to `main` when unset.
# STOUT_HUB_BRANCH=main

# The hub access token is NOT read from the environment: it is stored encrypted by
# the OS keychain (Electron safeStorage) and never written in plaintext.
